rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users can only read/write their own user document
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }
    
    // Interests can be read by their owner.
    // They can be created, updated, or deleted by their owner.
    match /interests/{interestId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Topics can be read by their owner.
    // They can be created, updated, or deleted by their owner.
    match /topics/{topicId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Goals can be read by their owner.
    // They can be created, updated, or deleted by their owner.
    match /goals/{goalId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Tasks can be read by their owner.
    // They can be created, updated, or deleted by their owner.
    match /tasks/{taskId} {
       allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // WikiPages can be read by their owner.
    // They can be created, updated, or deleted by their owner.
    match /wikiPages/{wikiPageId} {
       allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Loosened rules for watch rooms to allow public listing
    match /watchRooms/{roomId} {
      allow read; // Anyone can read (list and get)
      allow write: if isSignedIn(); // Only signed-in users can create/update
      
      // Messages can be read and created by any authenticated user.
      // We check ownership on create to prevent spoofing.
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      }
    }
    
    // Business cards can be read by anyone (publicly shareable).
    // They can only be created, updated, or deleted by their owner.
    match /businessCards/{cardId} {
      allow get;
      allow list: if isSignedIn() && request.query.where.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
