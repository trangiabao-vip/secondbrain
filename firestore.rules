rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users can only read/write their own user document
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }
    
    // Interests can be read by their owner.
    // They can be created, updated, or deleted by their owner.
    match /interests/{interestId} {
      allow get, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Topics can be read by their owner.
    // They can be created, updated, or deleted by their owner.
    match /topics/{topicId} {
      allow get, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Goals can be read by their owner.
    // They can be created, updated, or deleted by their owner.
    match /goals/{goalId} {
      allow get, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Tasks can be read by their owner.
    // They can be created, updated, or deleted by their owner.
    match /tasks/{taskId} {
       allow get, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
       allow list: if isSignedIn();
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}
